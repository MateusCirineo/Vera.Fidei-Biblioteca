DATABASE_URL=postgresql://vera:vera123@localhost:5432/vera_fidei
ELASTICSEARCH_URL=http://localhost:9200
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=BAAI/bge-m3
LLM_ENABLED=false
LLM_MODEL_NAME=qwen

# PDF storage
# local = usa backend/pdfs como hoje
# s3/r2 = envia novos PDFs para storage S3-compatible (Cloudflare R2, Backblaze B2, etc.)
# gdrive = envia novos PDFs para Google Drive via rclone
PDF_STORAGE=local
PDF_CACHE_DIR=/tmp/vera_fidei_pdf_cache
PDF_CACHE_MAX_GB=5
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=auto
S3_PREFIX=pdfs
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRES=3600
GDRIVE_REMOTE=vera_drive
GDRIVE_PREFIX=vera-fidei/pdfs
RCLONE_BIN=rclone
VERA_RCLONE_TIMEOUT=600
